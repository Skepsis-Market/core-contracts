# Environment Variables for Deployment
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ── Wallet ────────────────────────────────────────────────────────────────────
# DO NOT COMMIT .env WITH REAL VALUES
PRIVATE_KEY=
DEPLOYER_ADDRESS=
ADMIN_ADDRESS=

# ── Network: Arbitrum Sepolia ─────────────────────────────────────────────────
# RPC, e.g. https://sepolia-rollup.arbitrum.io/rpc
ARB_SEPOLIA_RPC_URL=
# Arbiscan API key for contract verification
ARBISCAN_API_KEY=

# ── Deployed contract addresses (filled in after DeployScript) ────────────────
USDC_ADDRESS=
LMSR_IMPL_ADDRESS=
POSITION_NFT_ADDRESS=
FACTORY_ADDRESS=
VAULT_ADDRESS=
TRADE_ROUTER_ADDRESS=
SAMPLE_MARKET_ADDRESS=

# ── Active market (set after CreateMarket.s.sol or pick from SAMPLE_MARKET_ADDRESS) ──
# Used by Trade.s.sol, Resolve.s.sol, and Claim.s.sol
MARKET_ADDRESS=
CHAINLINK_ORACLE_RESOLVER_ADDRESS=